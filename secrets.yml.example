---
# Domain name for the VPN server
domain: your-domain.com

# Xray configuration
xray:
  clients:
    - id: "your-client-uuid-here"
      email: "client-name"
      flow: "xtls-rprx-vision"
    # Add more clients as needed
shadowsocks:
  port: 54321 # Change it
  password: "your-shadowsocks-password-here"
