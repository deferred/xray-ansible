server {
    listen 80;
    server_name {{ domain }};
    root {{ nginx_website_root }};
    index index.html;

    location / {
        return 301 https://$server_name$request_uri;
    }

    # Allow acme challenge
    location /.well-known/acme-challenge/ {
        try_files $uri $uri/ =404;
    }
}

server {
    listen 127.0.0.1:8443 ssl;
    server_name {{ domain }};

    root {{ nginx_website_root }};
    index index.html;

    ssl_certificate     {{ acme_cert_path }};
    ssl_certificate_key {{ acme_key_path }};

    location / {
        try_files $uri $uri/ =404;
    }
}